# Application
APP_NAME=True Structure Assurance OS
APP_ENV=production
JWT_SECRET=your-secret-key-here-minimum-32-chars
JWT_EXPIRES_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# CORS - comma separated list of allowed origins
CORS_ORIGINS=["https://app.yourdomain.com","https://yourdomain.com"]

# Storage (use 'local' for Railway/Render free tier, 'minio' for S3-compatible)
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=assurance-os
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# AI Provider (use 'mock' for demo, 'openai' for production)
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Redis
REDIS_URL=redis://localhost:6379/0

# Feature flags
ENABLE_AI=true
ENABLE_SIGNUPS=false
MAX_UPLOAD_SIZE_MB=25
